// LumenReel Database Schema
// AI-native video generation platform for Hollywood

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]
}

model Job {
  id              String           @id @default(cuid())
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userPrompt      String           @db.Text // Original prompt - NEVER modified after creation
  displayName     String?          // Optional custom name for sidebar display
  settings        Json             // {aspectRatio, resolution, duration}
  status          String           @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  currentStage    String?
  finalVideoUrl   String?
  retentionDays   Int              @default(30) // -1 for permanent
  iterations      Iteration[]
  referenceImages ReferenceImage[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([projectId])
  @@index([status])
}

model Iteration {
  id             String   @id @default(cuid())
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  number         Int
  enhancedPrompt String   @db.Text
  videoUrl       String?
  analysisResult Json?    // {answer: "yes"|"no", explanation: string}
  status         String   // ENHANCING, GENERATING, ANALYZING, COMPLETED, FAILED
  createdAt      DateTime @default(now())

  @@index([jobId])
}

model ReferenceImage {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  createdAt DateTime @default(now())

  @@index([jobId])
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("invite_page") // Where they signed up from
  status    String   @default("pending") // pending, invited, rejected
  notes     String?  // Admin notes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}
